# Widget defaults for local/dev integration examples
DEMO_REGISTRY_BASE_URL=https://example.com
DEMO_REGISTRY_PATH=/registry.tsv
DEMO_REGISTRY_CACHE_KEY_PREFIX=demo-registry
DEMO_REGISTRY_MAX_AGE_MS=604800000
DEMO_WIDGET_BUTTON_ID=demosBtn
DEMO_WIDGET_POPOVER_ID=demosPopover
DEMO_WIDGET_CONTENT_ID=demosContent
DEMO_WIDGET_LIMIT=8
DEMO_WIDGET_SORT=none

# Script/runtime parameters used by repo test scripts
NPM_CACHE_DIR=.npm-cache
NPM_LOGS_DIR=.npm-cache/_logs
